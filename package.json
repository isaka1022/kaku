{
  "name": "kaku",
  "displayName": "kaku — 日本語 Markdown WYSIWYG エディタ",
  "description": "Markdown を紙のような画面で書く、日本語執筆に最適化した WYSIWYG エディタ",
  "version": "0.0.5",
  "publisher": "isaka1022",
  "license": "MIT",
  "icon": "media/icon.png",
  "keywords": [
    "markdown",
    "japanese",
    "wysiwyg",
    "writing",
    "editor",
    "日本語",
    "執筆",
    "novel",
    "note-taking"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isaka1022/kaku.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "type": "module",
  "main": "./dist/extension.cjs",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCustomEditor:kaku.editor"
  ],
  "contributes": {
    "customEditors": [
      {
        "viewType": "kaku.editor",
        "displayName": "kaku (執筆モード)",
        "selector": [
          {
            "filenamePattern": "*.md"
          }
        ],
        "priority": "option"
      }
    ],
    "commands": [
      {
        "command": "kaku.openWith",
        "title": "kaku: 執筆モードで開く",
        "icon": "$(edit)"
      },
      {
        "command": "kaku.revealCommentsFile",
        "title": "kaku: コメントファイルを開く"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "kaku.openWith",
          "when": "resourceExtname == .md && activeCustomEditorId != 'kaku.editor'",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "kaku.openWith",
          "when": "resourceExtname == .md"
        },
        {
          "command": "kaku.revealCommentsFile",
          "when": "resourceExtname == .md"
        }
      ]
    },
    "configuration": {
      "title": "kaku",
      "properties": {
        "kaku.typeface": {
          "type": "string",
          "enum": [
            "gothic",
            "mincho"
          ],
          "default": "gothic",
          "description": "本文の書体。gothic（ゴシック）または mincho（明朝）。"
        },
        "kaku.comments.contextChars": {
          "type": "number",
          "default": 40,
          "description": "コメントのアンカーとして保存する前後の文脈の文字数。"
        }
      }
    },
    "configurationDefaults": {
      "files.exclude": {
        "**/*.md.comments.json": true
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "node esbuild.mjs --production",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "vsce package"
  },
  "dependencies": {
    "@tiptap/core": "^3.28.0",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "@tiptap/extension-bubble-menu": "^3.28.0",
    "@tiptap/extension-link": "^3.28.0",
    "@tiptap/extension-placeholder": "^3.28.0",
    "@tiptap/extension-table": "^3.28.0",
    "@tiptap/extension-table-cell": "^3.28.0",
    "@tiptap/extension-table-header": "^3.28.0",
    "@tiptap/extension-table-row": "^3.28.0",
    "@tiptap/extension-task-item": "^3.28.0",
    "@tiptap/extension-task-list": "^3.28.0",
    "tiptap-markdown": "^0.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.28.1",
    "happy-dom": "^20.10.6",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  }
}
